# ---------------------------------------------------------------------------
# TaxiKiwi - local development environment
# ---------------------------------------------------------------------------
# Copy this file to .env before starting local services:
#   PowerShell: Copy-Item .env.example .env
#   macOS/Linux: cp .env.example .env
#
# Start the infrastructure:
#   docker compose --env-file .env -f docker/docker-compose.yml up -d
#
# Never commit real secrets. Values below are development defaults only.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=taxikiwi
TZ=UTC
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug

PORT=3000
API_PORT=3000
API_HOST=0.0.0.0
ADMIN_PORT=3001
ADMIN_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ---------------------------------------------------------------------------
# Security - replace these values in your private .env
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-only-change-me-access-secret-32chars
JWT_REFRESH_SECRET=dev-only-change-me-refresh-secret-32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=90d
COOKIE_SECRET=dev-only-change-me-cookie-secret-32chars
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ---------------------------------------------------------------------------
# PostgreSQL + PostGIS
# Image: postgis/postgis:16-3.5
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_HOST_DOCKER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taxikiwi
POSTGRES_USER=taxikiwi
POSTGRES_PASSWORD=taxikiwi_dev_password
POSTGRES_SCHEMA=public

# Use this URL when the application runs directly on your host machine.
DATABASE_URL=postgresql://taxikiwi:taxikiwi_dev_password@localhost:5432/taxikiwi?schema=public

# Use this URL only for application containers attached to the Compose network.
DATABASE_URL_DOCKER=postgresql://taxikiwi:taxikiwi_dev_password@postgres:5432/taxikiwi?schema=public

DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
TYPEORM_LOGGING=true

# ---------------------------------------------------------------------------
# Redis
# Image: redis:7-alpine
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_HOST_DOCKER=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
REDIS_KEY_PREFIX=taxikiwi:

BULLMQ_PREFIX=taxikiwi
BULLMQ_DEFAULT_JOB_ATTEMPTS=3
BULLMQ_DEFAULT_BACKOFF_MS=5000

# ---------------------------------------------------------------------------
# Mailpit
# Image: axllent/mailpit:v1.29
# ---------------------------------------------------------------------------
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
MAILPIT_MAX_MESSAGES=5000

SMTP_HOST=localhost
SMTP_HOST_DOCKER=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@taxikiwi.local
MAIL_FROM_NAME=TaxiKiwi
INVITATION_BASE_URL=http://localhost:3001/accept-invite
RESET_PASSWORD_BASE_URL=http://localhost:3001/reset-password

# ---------------------------------------------------------------------------
# Adminer
# Image: adminer:5.4.2
# ---------------------------------------------------------------------------
ADMINER_PORT=8080
ADMINER_DEFAULT_SERVER=postgres
ADMINER_DESIGN=pepa-linha
